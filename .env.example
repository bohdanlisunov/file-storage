APP_NAME="File Storage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=filestorage
DB_USERNAME=laraveluser
DB_PASSWORD=secret123

CACHE_DRIVER=file
FILESYSTEM_DISK=local
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=file_notifications
RABBITMQ_EXCHANGE=file_events

# Email address to receive file deletion notifications
NOTIFICATION_EMAIL=admin@example.com

# Maximum upload file size in KB (10240 = 10MB)
MAX_FILE_SIZE_KB=10240
